<Window x:Class="AshaLive.ConversationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        Title="ASHA conversation" Width="390" Height="420" MinWidth="280" MinHeight="220"
        WindowStyle="None" ResizeMode="NoResize" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="True" Closing="Window_Closing">
    <Border Margin="8" Padding="16" CornerRadius="22" Background="#F3FAFFFF" BorderBrush="#B7D9F5" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="26" ShadowDepth="7" Opacity="0.25" Color="#173E70" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="16" />
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Padding="0,0,0,10" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock FontSize="17" FontWeight="SemiBold" Foreground="#173E70">ASHA conversation</TextBlock>
                        <TextBlock Margin="0,2,0,0" FontSize="11" Foreground="#62788D">A readable view of the shared-attention session</TextBlock>
                    </StackPanel>
                    <Button Grid.Column="1" Padding="9,4" Click="Hide_Click" ToolTip="Hide chat">×</Button>
                </Grid>
            </Border>
            <ListBox x:Name="ConversationList" Grid.Row="1" BorderThickness="0" Background="Transparent"
                     ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,8" Padding="10,8" CornerRadius="12" Background="#EAF4FFFF">
                            <StackPanel>
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Left" FontSize="11" FontWeight="SemiBold" Foreground="#295A8D" Text="{Binding Speaker}" />
                                    <TextBlock DockPanel.Dock="Right" FontSize="10" Foreground="#71869B" Text="{Binding Timestamp, StringFormat={}{0:HH:mm}}" />
                                </DockPanel>
                                <TextBlock Margin="0,3,0,0" FontSize="13" Foreground="#234261" TextWrapping="Wrap" Text="{Binding Text}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <primitives:Thumb Grid.Row="2" Cursor="SizeNWSE" DragDelta="ResizeThumb_DragDelta" ToolTip="Drag to resize">
                <primitives:Thumb.Template>
                    <ControlTemplate TargetType="primitives:Thumb">
                        <Border Padding="0,7,0,0">
                            <Border Width="46" Height="3" HorizontalAlignment="Center" CornerRadius="2" Background="#B7CCE1" />
                        </Border>
                    </ControlTemplate>
                </primitives:Thumb.Template>
            </primitives:Thumb>
        </Grid>
    </Border>
</Window>
