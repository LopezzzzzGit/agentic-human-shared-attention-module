<Window x:Class="AshaLive.SessionLibraryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ASHA sessions" Width="520" Height="480" MinWidth="420" MinHeight="340"
        WindowStyle="None" ResizeMode="CanResizeWithGrip" AllowsTransparency="False"
        Background="#F4FAFF" ShowInTaskbar="True">
    <Border Padding="18" Background="#F4FAFF" BorderBrush="#AFCFEA" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="#173E70">Sessions</TextBlock>
                    <TextBlock Margin="0,3,0,0" FontSize="11" Foreground="#62788D">Continue a retained conversation with its own memory.</TextBlock>
                </StackPanel>
                <Button Grid.Column="1" Padding="10,5" Click="Close_Click" ToolTip="Close session library">×</Button>
            </Grid>

            <TextBlock Grid.Row="1" Margin="0,16,0,8" FontSize="11" Foreground="#526A84" TextWrapping="Wrap"
                       Text="The full transcript and semantic event log stay local. Memory summaries are derived context and never replace the complete record." />

            <ListBox x:Name="SessionList" Grid.Row="2" SelectionChanged="SessionList_SelectionChanged"
                     BorderBrush="#C9DFF2" BorderThickness="1" Background="White"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="5" Padding="11,9" CornerRadius="10" Background="#EDF7FFFF">
                            <StackPanel>
                                <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="#214E7D" Text="{Binding Title}" TextTrimming="CharacterEllipsis" />
                                <TextBlock Margin="0,3,0,0" FontSize="11" Foreground="#526A84" Text="{Binding ProjectAndState}" />
                                <TextBlock Margin="0,2,0,0" FontSize="10" Foreground="#71869B" Text="{Binding UpdatedDisplay}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Grid Grid.Row="3" Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Padding="12,7" Click="NewSession_Click">New session</Button>
                <TextBlock x:Name="LibraryStatusText" Grid.Column="1" Margin="12,0" VerticalAlignment="Center" FontSize="10" Foreground="#62788D" TextWrapping="Wrap" />
                <Button x:Name="ContinueButton" Grid.Column="2" Padding="12,7" Click="Continue_Click" IsEnabled="False">Continue selected</Button>
            </Grid>
        </Grid>
    </Border>
</Window>
