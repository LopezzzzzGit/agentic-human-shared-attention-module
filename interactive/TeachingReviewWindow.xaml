<Window x:Class="AshaLive.TeachingReviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ASHA teaching review" Width="760" Height="680" MinWidth="580" MinHeight="440"
        WindowStartupLocation="CenterOwner" Background="#F6FBFF">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <StackPanel>
            <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="#173E70">Review teaching episode</TextBlock>
            <TextBlock Margin="0,5,0,0" TextWrapping="Wrap" Foreground="#526A84">
                Conversation gives the action meaning. Pointing events are context anchors; demonstration events are possible procedure actions. Untick noise before creating a draft. The original recording is never changed.
            </TextBlock>
        </StackPanel>
        <ListBox Grid.Row="1" Margin="0,15,0,14" ItemsSource="{Binding Items}" BorderThickness="0" Background="Transparent"
                 ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,0,0,8" Padding="11,9" CornerRadius="12" Background="#EAF4FF" BorderBrush="#D4E5F4" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0" VerticalAlignment="Top" IsChecked="{Binding Include}" IsEnabled="{Binding CanInclude}" ToolTip="Keep as episode evidence" />
                            <TextBlock Grid.Column="1" FontSize="11" Foreground="#607992" Text="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}" />
                            <StackPanel Grid.Column="2">
                                <TextBlock FontWeight="SemiBold" Foreground="#214E7D" Text="{Binding Summary}" TextWrapping="Wrap" />
                                <TextBlock Margin="0,2,0,0" FontSize="10" Foreground="#71869B" Text="{Binding App}" />
                                <TextBox Margin="0,6,0,0" Padding="5,3" FontSize="11" Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding CanInclude}" ToolTip="Optional human label for the curated episode" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <DockPanel Grid.Row="2">
            <TextBlock VerticalAlignment="Center" Foreground="#62788D" Text="Save curation first; only kept demonstration actions become a procedure draft." />
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Padding="12,6" Click="Save_Click">Save curation</Button>
                <Button Margin="8,0,0,0" Padding="12,6" Click="Close_Click">Close</Button>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
